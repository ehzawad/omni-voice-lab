venv/
env/

# uv
uv.lock

# Logs and scratch
*.log
.*.log
scratch/
tmp/

# Generated audio at the repo root (examples/ outputs are committed deliberately)
/*.wav
/*.mp3

# Bulk regenerable fine-tune eval audio (keep only a small base-vs-LoRA A/B sample).
